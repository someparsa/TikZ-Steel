\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{tikzSteel}[2026/05/23 v0.1.0 Draw steel cross-sections with TikZ]

\RequirePackage{tikz}
\usetikzlibrary{calc}

%
% ===== ===== Package styles
%

\tikzset{
	tikzSteel/default/.style={line cap=round, line join=round},
	tikzSteel/straight/.style={tikzSteel/default, red},
	tikzSteel/round/.style={tikzSteel/default, blue},
	tikzSteel/centerline/.style={tikzSteel/default, black, dashed},
	tikzSteel/hidden/.style={tikzSteel/default, black!50, dashed},
	tikzSteel/dimension/.style={tikzSteel/default, black, <->},
	tikzSteel/label/.style={black},
	tikzSteel/fill/.style={fill=gray!20}
}

%
% ===== ===== Internal drawing helpers
%

\makeatletter
\newcommand{\tikzSteel@straightSegment}[3]{%
	\draw [tikzSteel/straight, line width=#1 mm] #2 -- #3;%
}

\newcommand{\tikzSteel@roundArc}[5]{%
	\draw [tikzSteel/round, line width=#1 mm] #2 arc (#3:#4:#5);%
}
\makeatother

%
% ===== ===== Cold-formed steel sections
%

%
% ===== ===== Channels
%

\newcommand{\csChannel}[7]{
	\draw [line width=#6 mm, tikzSteel/straight] (#7,0) -- (#4-#7,0) ;
	\draw [line width=#6 mm, tikzSteel/straight] (0,#7) -- (0,#1-#7) ;
	\draw [line width=#6 mm, tikzSteel/straight] (#7,#1) -- (#2-#7,#1) ;

	\draw [line width=#6 mm, tikzSteel/round] (0,#7) arc (180:270:#7);
	\draw [line width=#6 mm, tikzSteel/round] (0,#1-#7) arc (180:90:#7);

	\ifdim #3 pt > 0pt
    		\draw [line width=#6 mm, tikzSteel/straight] (#2,#1-#7) -- (#2,#1-#3) ;
		\draw [line width=#6 mm, tikzSteel/round] (#2-#7,#1) arc (90:0:#7);
	\fi

	\ifdim #5 pt > 0pt
    		\draw [line width=#6 mm, tikzSteel/straight] (#4,#7) -- (#4,#5) ;
		\draw [line width=#6 mm, tikzSteel/round] (#4-#7,0) arc (270:360:#7);
	\fi
}

\newcommand{\csChannelOS}[7]{
	\draw [line width=#6 mm, tikzSteel/straight] (#7,0) -- (#4-#7,0) ;
	\draw [line width=#6 mm, tikzSteel/straight] (#7,#1) -- (#2-#7,#1) ;
	
	\draw [line width=#6 mm, tikzSteel/straight] (0,#7) -- (0,{#7 + 0.45*(#1-2*#7)}) ;

	\draw [line width=#6 mm, tikzSteel/straight] (0,{#7 + 0.45*(#1-2*#7)}) -- ({0.05*(#1-2*#7)},{#7 + 0.5*(#1-2*#7)}) ;
	\draw [line width=#6 mm, tikzSteel/straight] ({0.05*(#1-2*#7)},{#7 + 0.5*(#1-2*#7)}) -- (0,{#7 + 0.55*(#1-2*#7)}) ;
	\draw [line width=#6 mm, tikzSteel/straight] (0,{#7 + 0.55*(#1-2*#7)}) -- (0,#1-#7) ;

	\draw [line width=#6 mm, tikzSteel/round] (0,#7) arc (180:270:#7);
	\draw [line width=#6 mm, tikzSteel/round] (0,#1-#7) arc (180:90:#7);

	\ifdim #3 pt > 0pt
    		\draw [line width=#6 mm, tikzSteel/straight] (#2,#1-#7) -- (#2,#1-#3) ;
		\draw [line width=#6 mm, tikzSteel/round] (#2-#7,#1) arc (90:0:#7);
	\fi

	\ifdim #5 pt > 0pt
    		\draw [line width=#6 mm, tikzSteel/straight] (#4,#7) -- (#4,#5) ;
		\draw [line width=#6 mm, tikzSteel/round] (#4-#7,0) arc (270:360:#7);
	\fi
}


\newcommand{\csChannelTS}[7]{
	\draw [line width=#6 mm, tikzSteel/straight] (#7,0) -- (#4-#7,0) ;
	\draw [line width=#6 mm, tikzSteel/straight] (#7,#1) -- (#2-#7,#1) ;
	
	\draw [line width=#6 mm, tikzSteel/straight] (0,#7) -- (0,{#7 + 0.05*(#1-2*#7)}) ;
	\draw [line width=#6 mm, tikzSteel/straight] (0,#1-#7) -- (0,{#7 + 0.95*(#1-2*#7)}) ;
	
	\draw [line width=#6 mm, tikzSteel/straight] (0,{#7 + 0.05*(#1-2*#7)}) -- ({0.05*(#1-2*#7)},{#7 + 0.1*(#1-2*#7)}) ;
	\draw [line width=#6 mm, tikzSteel/straight] ({0.05*(#1-2*#7)},{#7 + 0.1*(#1-2*#7)}) -- (0,{#7 + 0.15*(#1-2*#7)}) ;
	\draw [line width=#6 mm, tikzSteel/straight] (0,{#7 + 0.15*(#1-2*#7)}) -- (0,{#7 + 0.85*(#1-2*#7)}) ;
	\draw [line width=#6 mm, tikzSteel/straight] (0,{#7 + 0.85*(#1-2*#7)}) -- ({0.05*(#1-2*#7)},{#7 + 0.9*(#1-2*#7)}) ;
	\draw [line width=#6 mm, tikzSteel/straight] ({0.05*(#1-2*#7)},{#7 + 0.9*(#1-2*#7)}) -- (0,{#7 + 0.95*(#1-2*#7)}) ;
	\draw [line width=#6 mm, tikzSteel/straight] (0,{#7 + 0.95*(#1-2*#7)}) -- (0,#1-2*#7) ;
	
	\draw [line width=#6 mm, tikzSteel/round] (0,#7) arc (180:270:#7);
	\draw [line width=#6 mm, tikzSteel/round] (0,#1-#7) arc (180:90:#7);

	\ifdim #3 pt > 0pt
    		\draw [line width=#6 mm, tikzSteel/straight] (#2,#1-#7) -- (#2,#1-#3) ;
		\draw [line width=#6 mm, tikzSteel/round] (#2-#7,#1) arc (90:0:#7);
	\fi

	\ifdim #5 pt > 0pt
    		\draw [line width=#6 mm, tikzSteel/straight] (#4,#7) -- (#4,#5) ;
		\draw [line width=#6 mm, tikzSteel/round] (#4-#7,0) arc (270:360:#7);
	\fi
}

\newcommand{\csChannelFS}[8]{
	\draw [line width=#6 mm, tikzSteel/straight] (#7,0) -- (#4-#7,0) ;
	\draw [line width=#6 mm, tikzSteel/straight] (#7,#1) -- (#2-#7,#1) ;
	
	\draw [line width=#6 mm, tikzSteel/straight] (0,#7) -- (0,{#7 + (#8-0.05)*(#1-2*#7)}) ;

	\draw [line width=#6 mm, tikzSteel/straight] (0,{#7 + (#8-0.05)*(#1-2*#7)}) -- ({0.05*(#1-2*#7)},{#7 + (#8)*(#1-2*#7)}) ;
	\draw [line width=#6 mm, tikzSteel/straight] ({0.05*(#1-2*#7)},{#7 + (#8)*(#1-2*#7)}) -- (0,{#7 + (#8+0.05)*(#1-2*#7)}) ;
	\draw [line width=#6 mm, tikzSteel/straight] (0,{#7 + (#8+0.05)*(#1-2*#7)}) -- (0,#1-#7) ;

	\draw [line width=#6 mm, tikzSteel/round] (0,#7) arc (180:270:#7);
	\draw [line width=#6 mm, tikzSteel/round] (0,#1-#7) arc (180:90:#7);

	\ifdim #3 pt > 0pt
    		\draw [line width=#6 mm, tikzSteel/straight] (#2,#1-#7) -- (#2,#1-#3) ;
		\draw [line width=#6 mm, tikzSteel/round] (#2-#7,#1) arc (90:0:#7);
	\fi

	\ifdim #5 pt > 0pt
    		\draw [line width=#6 mm, tikzSteel/straight] (#4,#7) -- (#4,#5) ;
		\draw [line width=#6 mm, tikzSteel/round] (#4-#7,0) arc (270:360:#7);
	\fi
}

\newcommand{\csChannelRS}[8]{
	\draw [line width=#6 mm, tikzSteel/straight] (#7,0) -- (#4-#7,0) ;
	\draw [line width=#6 mm, tikzSteel/straight] (#7,#1) -- (#2-#7,#1) ;
	
	\draw [line width=#6 mm, tikzSteel/straight] (0,#7) -- (0,{#7 + 0.05*(#1-2*#7)}) ;
	\draw [line width=#6 mm, tikzSteel/straight] (0,#1-#7) -- (0,{#7 + 0.95*(#1-2*#7)}) ;
	
	\draw [line width=#6 mm, tikzSteel/straight] (0,{#7 + 0.05*(#1-2*#7)}) -- ({0.05*(#1-2*#7)},{#7 + 0.1*(#1-2*#7)}) ;
	\draw [line width=#6 mm, tikzSteel/straight] ({0.05*(#1-2*#7)},{#7 + 0.1*(#1-2*#7)}) -- (0,{#7 + 0.15*(#1-2*#7)}) ;
	\draw [line width=#6 mm, tikzSteel/straight] (0,{#7 + 0.15*(#1-2*#7)}) -- (0,{#7 + (#8-0.05)*(#1-2*#7)}) ;
	
	\draw [line width=#6 mm, tikzSteel/straight] (0,{#7 + (#8-0.05)*(#1-2*#7)}) -- ({0.05*(#1-2*#7)},{#7 + (#8)*(#1-2*#7)}) ;
	\draw [line width=#6 mm, tikzSteel/straight] ({0.05*(#1-2*#7)},{#7 + (#8)*(#1-2*#7)}) -- (0,{#7 + (#8+0.05)*(#1-2*#7)}) ;
	\draw [line width=#6 mm, tikzSteel/straight] (0,{#7 + (#8+0.05)*(#1-2*#7)}) -- (0,{#7 + 0.85*(#1-2*#7)}) ;
	
	\draw [line width=#6 mm, tikzSteel/straight] (0,{#7 + 0.85*(#1-2*#7)}) -- ({0.05*(#1-2*#7)},{#7 + 0.9*(#1-2*#7)}) ;
	\draw [line width=#6 mm, tikzSteel/straight] ({0.05*(#1-2*#7)},{#7 + 0.9*(#1-2*#7)}) -- (0,{#7 + 0.95*(#1-2*#7)}) ;
	\draw [line width=#6 mm, tikzSteel/straight] (0,{#7 + 0.95*(#1-2*#7)}) -- (0,#1-2*#7) ;
	
	\draw [line width=#6 mm, tikzSteel/round] (0,#7) arc (180:270:#7);
	\draw [line width=#6 mm, tikzSteel/round] (0,#1-#7) arc (180:90:#7);

	\ifdim #3 pt > 0pt
    		\draw [line width=#6 mm, tikzSteel/straight] (#2,#1-#7) -- (#2,#1-#3) ;
		\draw [line width=#6 mm, tikzSteel/round] (#2-#7,#1) arc (90:0:#7);
	\fi

	\ifdim #5 pt > 0pt
    		\draw [line width=#6 mm, tikzSteel/straight] (#4,#7) -- (#4,#5) ;
		\draw [line width=#6 mm, tikzSteel/round] (#4-#7,0) arc (270:360:#7);
	\fi
}

%
% ===== ===== Box
%

\newcommand{\csBox}[4]{
	\draw [line width=#3 mm, tikzSteel/straight] (#4,0) -- (#2-#4,0) ;
	\draw [line width=#3 mm, tikzSteel/straight] (#4,#1) -- (#2-#4,#1) ;	
	\draw [line width=#3 mm, tikzSteel/straight] (0,#4) -- (0,#1-#4) ;
	\draw [line width=#3 mm, tikzSteel/straight] (#2,#4) -- (#2,#1-#4) ;
	
	\draw [line width=#3 mm, tikzSteel/round] (0,#4) arc (180:270:#4);
	\draw [line width=#3 mm, tikzSteel/round] (0,#1-#4) arc (180:90:#4);

	\draw [line width=#3 mm, tikzSteel/round] (#2-#4,0) arc (270:360:#4);
	\draw [line width=#3 mm, tikzSteel/round] (#2-#4,#1) arc (90:0:#4);
}

%
% ===== ===== Zee
%

\newcommand{\csZee}[7]{
	\draw [line width=#6 mm, tikzSteel/straight] (0,#7) -- (0,#1-#7) ;	
	\draw [line width=#6 mm, tikzSteel/straight] (#7,#1) -- (#2-#7,#1) ;
	\draw [line width=#6 mm, tikzSteel/straight] (-#7,0) -- (#7-#4,0) ;

	\draw [line width=#6 mm, tikzSteel/round] (0,#1-#7) arc (180:90:#7);
	\draw [line width=#6 mm, tikzSteel/round] (0,#7) arc (0:-90:#7);

	\ifdim #3 pt > 0pt
		\draw [line width=#6 mm, tikzSteel/straight] (#2,#1-#7) -- (#2,#1-#3) ;
		\draw [line width=#6 mm, tikzSteel/round] (#2-#7,#1) arc (90:0:#7);
	\fi

	\ifdim #5 pt > 0pt
		\draw [line width=#6 mm, tikzSteel/straight] (-#4,#7) -- (-#4,#5) ;
		\draw [line width=#6 mm, tikzSteel/round] (#7-#4,0) arc (270:180:#7);
	\fi
}

%
% ===== ===== L
%

\newcommand{\csL}[4]{
	\draw [line width=#3 mm, tikzSteel/straight] (0,#4) -- (0,#1) ;	
	\draw [line width=#3 mm, tikzSteel/straight] (#4,0) -- (#2,0) ;

	\draw [line width=#3 mm, tikzSteel/round] (0,#4) arc (180:270:#4);

}

%
% ===== ===== Tube
%
\newcommand{\csTube}[2]{
	\draw [line width=#2 mm, tikzSteel/round] (0,0) arc (0:360:#1);
}

%
% ===== ===== CFS public wrappers and additional sections
%

\newcommand{\csCFSChannel}[4]{
	\csChannel{#1}{#2}{0}{#2}{0}{#3}{#4}
}

\newcommand{\csCFSLippedChannel}[5]{
	\csChannel{#1}{#2}{#3}{#2}{#3}{#4}{#5}
}

\newcommand{\csCFSEdgeStiffenedChannel}[5]{
	\csCFSLippedChannel{#1}{#2}{#3}{#4}{#5}
}

\newcommand{\csCFSChannelWithOneStiffener}[8]{
	\csChannelFS{#1}{#2}{#3}{#4}{#5}{#6}{#7}{#8}
}

\newcommand{\csCFSChannelWithTwoStiffeners}[7]{
	\csChannelTS{#1}{#2}{#3}{#4}{#5}{#6}{#7}
}

\newcommand{\csCFSChannelWithThreeStiffeners}[8]{
	\csChannelRS{#1}{#2}{#3}{#4}{#5}{#6}{#7}{#8}
}

\newcommand{\csCFSZee}[4]{
	\csZee{#1}{#2}{0}{#2}{0}{#3}{#4}
}

\newcommand{\csCFSLippedZee}[5]{
	\csZee{#1}{#2}{#3}{#2}{#3}{#4}{#5}
}

\newcommand{\csCFSSigma}[7]{
	\csChannelTS{#1}{#2}{#3}{#4}{#5}{#6}{#7}
}

\newcommand{\csCFSHat}[6]{
	\draw [line width=#5 mm, tikzSteel/straight] (0,#6) -- (0,#1-#6) ;
	\draw [line width=#5 mm, tikzSteel/straight] (0,#1) -- (#2,#1) ;
	\draw [line width=#5 mm, tikzSteel/straight] (#2,#1-#6) -- (#2,#6) ;
	\draw [line width=#5 mm, tikzSteel/straight] (#2+#6,0) -- (#2+#3-#6,0) ;
	\draw [line width=#5 mm, tikzSteel/straight] (#2+#3,#6) -- (#2+#3,#1-#6) ;
	\draw [line width=#5 mm, tikzSteel/straight] (#2+#3,#1) -- (#2+#3+#4,#1) ;

	\draw [line width=#5 mm, tikzSteel/round] (0,#1-#6) arc (180:90:#6);
	\draw [line width=#5 mm, tikzSteel/round] (#2,#1-#6) arc (0:90:#6);
	\draw [line width=#5 mm, tikzSteel/round] (#2,#6) arc (180:270:#6);
	\draw [line width=#5 mm, tikzSteel/round] (#2+#3,#6) arc (0:-90:#6);
	\draw [line width=#5 mm, tikzSteel/round] (#2+#3,#1-#6) arc (180:90:#6);
}

\newcommand{\csCFSAngle}[4]{
	\csL{#1}{#2}{#3}{#4}
}

\newcommand{\csCFSLippedAngle}[5]{
	\draw [line width=#3 mm, tikzSteel/straight] (0,#4) -- (0,#1) ;
	\draw [line width=#3 mm, tikzSteel/straight] (#4,0) -- (#2-#4,0) ;
	\draw [line width=#3 mm, tikzSteel/straight] (#2,#4) -- (#2,#5) ;

	\draw [line width=#3 mm, tikzSteel/round] (0,#4) arc (180:270:#4);
	\draw [line width=#3 mm, tikzSteel/round] (#2-#4,0) arc (270:360:#4);
}

\newcommand{\csCFSBox}[4]{
	\csBox{#1}{#2}{#3}{#4}
}

\newcommand{\csCFSRHS}[4]{
	\csBox{#1}{#2}{#3}{#4}
}

\newcommand{\csCFSSHS}[3]{
	\csBox{#1}{#1}{#2}{#3}
}

\newcommand{\csCFSCHS}[2]{
	\csTube{#1}{#2}
}

\newcommand{\csCFSFoldedPlate}[2]{
	\def\points{#1}
	\foreach \p [count=\i,remember=\p as \lastp] in \points{
		\ifnum\i>1\relax
			\draw [line width=#2 mm, tikzSteel/straight] \lastp -- \p;
		\fi
	}
}

%
% ===== ===== CFS built-up sections
%

\newcommand{\csCFSBackToBackChannels}[6]{
	\scope
		\csCFSLippedChannel{#1}{#2}{#3}{#4}{#5}
	\endscope
	\scope[shift={({#6 + 2*#2},0)}, xscale=-1]
		\csCFSLippedChannel{#1}{#2}{#3}{#4}{#5}
	\endscope
}

\newcommand{\csCFSToeToToeChannels}[6]{
	\scope
		\csCFSLippedChannel{#1}{#2}{#3}{#4}{#5}
	\endscope
	\scope[shift={({#6 - 2*#2},0)}, xscale=-1]
		\csCFSLippedChannel{#1}{#2}{#3}{#4}{#5}
	\endscope
}

\newcommand{\csCFSNestedChannels}[6]{
	\scope
		\csCFSLippedChannel{#1}{#2}{#3}{#4}{#5}
	\endscope
	\scope[shift={(#6,0)}]
		\csCFSLippedChannel{#1}{#2}{#3}{#4}{#5}
	\endscope
}

\newcommand{\csCFSBoxedChannels}[6]{
	\scope
		\csCFSLippedChannel{#1}{#2}{#3}{#4}{#5}
	\endscope
	\scope[shift={({#6 + #2},0)}, xscale=-1]
		\csCFSLippedChannel{#1}{#2}{#3}{#4}{#5}
	\endscope
}

\newcommand{\csCFSBuiltUpIChannels}[6]{
	\scope
		\csCFSChannel{#1}{#2}{#4}{#5}
	\endscope
	\scope[shift={({#6 + #2},0)}, xscale=-1]
		\csCFSChannel{#1}{#3}{#4}{#5}
	\endscope
}

\newcommand{\csCFSBackToBackZees}[6]{
	\scope
		\csCFSLippedZee{#1}{#2}{#3}{#4}{#5}
	\endscope
	\scope[shift={({#6 + 2*#2},0)}, xscale=-1]
		\csCFSLippedZee{#1}{#2}{#3}{#4}{#5}
	\endscope
}

\newcommand{\csCFSBackToBackAngles}[5]{
	\scope
		\csCFSAngle{#1}{#2}{#3}{#4}
	\endscope
	\scope[shift={({#5 + 2*#2},0)}, xscale=-1]
		\csCFSAngle{#1}{#2}{#3}{#4}
	\endscope
}

% Simple fastener indicators for built-up CFS section sketches.
\newcommand{\csCFSFasteners}[4]{
	\foreach \y in {#2,#3,...,#4}{
		\draw [tikzSteel/round, line width=#1 mm] (0,\y) circle [radius={2*#1}];
	}
}

%
% ===== ===== Hot-rolled steel sections
%

%
% ===== ===== Welded I
%
\newcommand{\csWI}[6]{
	\draw [line width=#2 mm, tikzSteel/straight] (0,-0.5*#1) -- (0,0.5*#1);
	\draw [line width=#4 mm, tikzSteel/round] (-0.5*#3,-0.5*#1) -- (0.5*#3,-0.5*#1);
	\draw [line width=#6 mm, tikzSteel/round] (-0.5*#5,0.5*#1) -- (0.5*#5,0.5*#1);
}

%
% ===== ===== Universal beams and columns
%
\newcommand{\csUBC}[5]{
	\draw [line width=1 mm, tikzSteel/straight] (0,0) -- (#2,0);
	\draw [line width=1 mm, tikzSteel/straight] (0,#1) -- (#2,#1);

	\draw [line width=1 mm, tikzSteel/straight] (0,#3) -- (0.5*#2-0.5*#4-#5,#3);
	\draw [line width=1 mm, tikzSteel/straight] (0.5*#2+0.5*#4+#5,#3) -- (#2,#3);

	\draw [line width=1 mm, tikzSteel/straight] (0,#1-#3) -- (0.5*#2-0.5*#4-#5,#1-#3);
	\draw [line width=1 mm, tikzSteel/straight] (0.5*#2+0.5*#4+#5,#1-#3) -- (#2,#1-#3);
	
	\draw [line width=1 mm, tikzSteel/straight] (0.5*#2-0.5*#4,#3+#5) -- (0.5*#2-0.5*#4,{#1 - (#3+#5)});
	\draw [line width=1 mm, tikzSteel/straight] (0.5*#2+0.5*#4,#3+#5) -- (0.5*#2+0.5*#4,{#1 - (#3+#5)});
	
	\draw [line width=1 mm, tikzSteel/round] (0.5*#2-0.5*#4-#5,#3) arc (270:360:#5);
	\draw [line width=1 mm, tikzSteel/round] (0.5*#2+0.5*#4+#5,#3) arc (270:180:#5);

	\draw [line width=1 mm, tikzSteel/round] (0.5*#2-0.5*#4-#5,#1-#3) arc (90:0:#5);
	\draw [line width=1 mm, tikzSteel/round] (0.5*#2+0.5*#4+#5,#1-#3) arc (90:180:#5);
	
	\draw [line width=1 mm, tikzSteel/straight] (0,0) -- (0,#3);
	\draw [line width=1 mm, tikzSteel/straight] (#2,0) -- (#2,#3);

	\draw [line width=1 mm, tikzSteel/straight] (0,#1-#3) -- (0,#1);
	\draw [line width=1 mm, tikzSteel/straight] (#2,#1-#3) -- (#2,#1);
}

%
% ===== ===== Tees cut from universal beams and columns
%
\newcommand{\csTU}[5]{
	\draw [line width=1 mm, tikzSteel/straight] (0,#1) -- (#2,#1);

	\draw [line width=1 mm, tikzSteel/straight] (0.5*#2-0.5*#4,0) -- (0.5*#2+0.5*#4,0);

	\draw [line width=1 mm, tikzSteel/straight] (0,#1-#3) -- (0.5*#2-0.5*#4-#5,#1-#3);
	\draw [line width=1 mm, tikzSteel/straight] (0.5*#2+0.5*#4+#5,#1-#3) -- (#2,#1-#3);

	\draw [line width=1 mm, tikzSteel/straight] (0.5*#2-0.5*#4,0) -- (0.5*#2-0.5*#4,{#1 - (#3+#5)});
	\draw [line width=1 mm, tikzSteel/straight] (0.5*#2+0.5*#4,0) -- (0.5*#2+0.5*#4,{#1 - (#3+#5)});

	\draw [line width=1 mm, tikzSteel/round] (0.5*#2-0.5*#4-#5,#1-#3) arc (90:0:#5);
	\draw [line width=1 mm, tikzSteel/round] (0.5*#2+0.5*#4+#5,#1-#3) arc (90:180:#5);

	\draw [line width=1 mm, tikzSteel/straight] (0,#1-#3) -- (0,#1);
	\draw [line width=1 mm, tikzSteel/straight] (#2,#1-#3) -- (#2,#1);
}

%
% ===== ===== HRS Channels
%
\newcommand{\csHCH}[5]{
	\draw [line width=1 mm, tikzSteel/straight] (0,0) -- (0,#1);
	
	\draw [line width=1 mm, tikzSteel/straight] (0,0) -- (#2,0);
	\draw [line width=1 mm, tikzSteel/straight] (0,#1) -- (#2,#1);

	\draw [line width=1 mm, tikzSteel/straight] (#4+#5,#3) -- (#2,#3);

	\draw [line width=1 mm, tikzSteel/straight] (#4+#5,#1-#3) -- (#2,#1-#3);
	
	\draw [line width=1 mm, tikzSteel/straight] (#4,#3+#5) -- (#4,{#1 - (#3+#5)});
	
	\draw [line width=1 mm, tikzSteel/round] (#4+#5,#3) arc (270:180:#5);

	\draw [line width=1 mm, tikzSteel/round] (#4+#5,#1-#3) arc (90:180:#5);
	
	\draw [line width=1 mm, tikzSteel/straight] (#2,0) -- (#2,#3);

	\draw [line width=1 mm, tikzSteel/straight] (#2,#1-#3) -- (#2,#1);
}

%
% ===== ===== HRS Angles
%
\newcommand{\csEA}[5]{
	\draw [line width=1 mm, tikzSteel/straight] (0,0) -- (0,#1);
	
	\draw [line width=1 mm, tikzSteel/straight] (0,0) -- (#2,0);
	\draw [line width=1 mm, tikzSteel/straight] (0,#1) -- (#4,#1);

	\draw [line width=1 mm, tikzSteel/straight] (#4+#5,#3) -- (#2,#3);

	\draw [line width=1 mm, tikzSteel/straight] (#4,#3+#5) -- (#4,#1);
	
	\draw [line width=1 mm, tikzSteel/round] (#4+#5,#3) arc (270:180:#5);

	
	\draw [line width=1 mm, tikzSteel/straight] (#2,0) -- (#2,#3);

}

