\newcommand{\csARB}[2]{
	\def\points{#1}
	\foreach \p [count=\i,remember=\p as \lastp] in \points{
		\ifnum\i>1\relax
			\draw [line width=#2 mm, tikzSteel/round] \lastp -- \p;
		\fi
	}
}
